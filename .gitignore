# dependencies
node_modules/

# secrets / local env (any directory)
.env
**/.env
*.env.local
# any .env variant or backup (e.g. .env.bak, .env.prod) — never commit these.
# The .env.example templates are the one exception.
**/.env.*
!**/.env.example

# hardhat
contracts/artifacts/
contracts/cache/

# besu generated network material (regenerate with setup-network.sh)
blockchain/networkFiles/
blockchain/Node-*/
blockchain/genesis.json

# evaluation harness (generated artifacts; node_modules covered above)
evaluation/.last-seed.json
evaluation/results/*
!evaluation/results/.gitkeep

# api (node_modules covered above; .env covered by **/.env)
api/.addresses.json

# logs / os
*.log
.DS_Store

# Copy to api/.env and adjust. NEVER commit the real .env (it is gitignored).
#
# KEY SAFETY (F-11): the signer/deployer keys below are the WELL-KNOWN, PUBLIC
# Hardhat/Besu TEST keys. They control NO real funds and are safe ONLY for this
# isolated, permissioned capstone network. They live HERE (server-side) and NOT in
# the browser: the dashboard talks to this API, the API signs. Never reuse them
# anywhere real. For any real deployment, generate FRESH per-org keys and store
# them in a secrets manager / HSM — never in a file like this. (Note: the old
# deployer key also exists in this repo's git history; purge it with git filter-repo
# or BFG before any public release.)

# --- where the API listens ---
PORT=3001
# Allowed browser origin for CORS (the dashboard). Use * for local dev.
CORS_ORIGIN=*

# --- chain wiring ---
# Main RPC the API reads/writes through (one Besu node is enough).
BESU_RPC_URL=http://127.0.0.1:8545
# All three validator RPCs — used ONLY by the API for the cross-node integrity
# check; these are never exposed to the browser.
NODE_RPC_URLS=http://127.0.0.1:8545,http://127.0.0.1:8546,http://127.0.0.1:8547

# Deployed contract addresses (paste what `npm run deploy:besu` printed; the
# defaults below are the deterministic fresh-chain addresses).
AGREEMENT_ADDRESS=0x42699A7612A82f1d9C36148af9C77354759b210b
COMPLIANCE_ADDRESS=0xa50a51c09a5c451C52BB714527E1974b686D8e77
VERIFICATION_ADDRESS=0x9a3DBCa554e9f6b9257aAa24010DA8377C57c17e

# --- document store (BL-12): Neon managed Postgres ---
# Holds the actual files (spend supporting docs, receipts, report evidence) keyed
# by their SHA-256; the chain stores only the hash. Get this from the Neon console
# (Connection Details → connection string). SSL is auto-enabled for non-localhost.
#   Neon example:  postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/macl?sslmode=require
#   Local example: postgresql://macl:macl@127.0.0.1:5432/macl_docs
# Leave unset to run the API without document storage (the upload/download/verify
# endpoints then return 503; all other endpoints work unchanged).
DATABASE_URL=
# Optional override of the SSL heuristic: "require" forces SSL, "disable" turns it off.
# DOCSTORE_SSL=require
# TLS verification (F-12): a remote DB is ALWAYS connected with the certificate
# verified — we never disable verification. To PIN the provider's CA (recommended),
# download it (Neon console → "Download CA certificate") and point PG_CA_CERT at it.
# If unset, the cert is still verified against the system CA store (works for Neon).
# PG_CA_CERT=/absolute/path/to/neon-ca.crt

# --- login / JWT (BL-13, hardened in S1) ---
# Secret used to sign session tokens. REQUIRED and FAIL-CLOSED (F-01): the API
# refuses to start if this is missing or shorter than 32 characters. There is no
# insecure default any more. Generate a strong value with:
#     openssl rand -hex 32
JWT_SECRET=
# Token lifetime (zeit/ms style, e.g. 12h, 1d).
JWT_TTL=12h
# Per-org login passwords are stored as bcrypt HASHES, never plaintext (F-03).
# Generate each hash from the chosen password with:
#     node scripts/hash-password.js '<the password>'
# then paste the printed hash below. A role with no hash here simply cannot log in.
# (username = the role name: donor / ngo / audit.)
DONOR_PW_HASH=
NGO_PW_HASH=
AUDIT_PW_HASH=

# --- signer keys (server-side only; TEST keys) ---
# Owner/deployer — used for owner-only actions (e.g. register organisation).
OWNER_PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63
# The three org roles. donor = Donor-Admin, ngo = NGO, audit = Ministry/Govt.
DONOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
NGO_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AUDIT_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

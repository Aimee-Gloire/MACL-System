# Copy to .env and adjust if your setup differs. Never commit the real .env.

# --- PostgreSQL baseline (the control group; see docker-compose.yml) ---
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=macl
PGPASSWORD=macl
PGDATABASE=macl_baseline

# --- MACL / Besu side ---
# Defaults to dashboard/config.js RPC_URL if unset. The three node endpoints
# used for cross-node checks are read from dashboard/config.js NODES.
BESU_RPC_URL=http://127.0.0.1:8545

# --- experiment knobs (optional) ---
# How many successive values to record for the audit-completeness metric.
EVAL_HISTORY_DEPTH=5
# Which validator to stop/restart for the consensus-recovery metric (1|2|3).
EVAL_RECOVERY_NODE=3
# Max seconds to wait for a rejoining node to resync before reporting failure.
EVAL_RECOVERY_TIMEOUT=120

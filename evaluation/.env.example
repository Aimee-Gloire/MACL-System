# Copy to .env and adjust if your setup differs. Never commit the real .env.

# --- PostgreSQL baseline (the control group; see docker-compose.yml) ---
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=macl
PGPASSWORD=macl
PGDATABASE=macl_baseline

# --- MACL / Besu side ---
# The harness is self-contained (it does NOT read dashboard/config.js). The values
# below default to the fresh-chain setup; override only if your deploy differs.
#
# Main RPC the harness reads/writes through (one node is enough for reads/writes).
BESU_RPC_URL=http://127.0.0.1:8545
# All three validator RPCs — used for the cross-node checks (tamper + recovery).
NODE_RPC_URLS=http://127.0.0.1:8545,http://127.0.0.1:8546,http://127.0.0.1:8547

# Deployed contract addresses. These are the deterministic fresh-chain addresses
# (same as api/.env.example); if you deploy onto a non-fresh chain, paste the new
# ones the deploy printed.
AGREEMENT_ADDRESS=0x42699A7612A82f1d9C36148af9C77354759b210b
COMPLIANCE_ADDRESS=0xa50a51c09a5c451C52BB714527E1974b686D8e77
VERIFICATION_ADDRESS=0x9a3DBCa554e9f6b9257aAa24010DA8377C57c17e

# Org signing keys (server-side only; these are the well-known PUBLIC Hardhat/Besu
# TEST keys — no real funds, safe ONLY on this isolated permissioned network).
DONOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
NGO_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AUDIT_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# --- experiment knobs (optional) ---
# How many successive values to record for the audit-completeness metric.
EVAL_HISTORY_DEPTH=5
# Which validator to stop/restart for the consensus-recovery metric (1|2|3).
EVAL_RECOVERY_NODE=3
# Max seconds to wait for a rejoining node to resync before reporting failure.
EVAL_RECOVERY_TIMEOUT=120
